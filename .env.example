# Server Configuration
HOST=0.0.0.0
PORT=8000

# Security (Defense-in-depth authorization)
# Must match the API_BEARER_TOKEN configured in the main Node app
API_BEARER_TOKEN=super-secret-folio-bridge-token

# Mutual TLS (disabled by default for internal network communication)
# Set MTLS_ENABLED=true and configure cert paths to enable mTLS.
# When disabled, the service runs in plain HTTP and relies on
# network isolation + Bearer token for security.
MTLS_ENABLED=false

# Mutual TLS Paths (only used when MTLS_ENABLED=true)
# CA_CERT_PATH=certs/ca.crt
# SERVER_CERT_PATH=certs/server.crt
# SERVER_KEY_PATH=certs/server.key

# Timeouts
SII_TIMEOUT=30
